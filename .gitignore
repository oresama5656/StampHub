# === StampHub Specific (Heavy Data & Local Config) ===
# Local configuration
config.json

# Logs
*.log
logs/

# --- Heavy Data Folders (Ignoring contents but keeping directory structure) ---
# Data/Images generated by UI
assets/images/*
!assets/images/.gitkeep

# Exported files
assets/export/ready/*
!assets/export/ready/.gitkeep
assets/export/archived_zips/*
!assets/export/archived_zips/.gitkeep
assets/export/raw_archives/*
!assets/export/raw_archives/.gitkeep

# Temporary workspace
workspace/WorkBench/*
!workspace/WorkBench/.gitkeep

# Specific File Extensions (Global ignore for heavy blobs)
*.zip
*.rar
*.7z
*.png
*.jpg
*.jpeg
*.webp
*.psd
*.ai

# --- Assets to Keep ---
!assets/prompts/
!assets/tags/
!assets/title_and_info/
!gui/assets/
!core/assets/

# Allow .gitkeep to be tracked everywhere
!**/.gitkeep
